app.post('/api/video/bulk-create', auth, upload.array('images', 100), async (req, res) => {
    const images = req.files;
    const { duration } = req.body;
    if (!images || images.length === 0) return res.status(400).json({ error: 'Images required' });
    
    const results = [];
    const durations = parseInt(duration) || 5;
    
    for (let i = 0; i < Math.min(images.length, 100); i++) {
        const image = images[i];
        const outputName = `${uuidv4()}.mp4`;
        const outputPath = path.join(__dirname, 'public/videos', outputName);
        
        try {
            await new Promise((resolve, reject) => {
                ffmpeg()
                    .input(image.path)
                    .loop(durations)
                    .inputOptions('-stream_loop -1')
                    .outputOptions([`-t ${durations}`, '-vf scale=1080:1920:force_original_aspect_ratio=decrease,pad=1080:1920:(ow-iw)/2:(oh-ih)/2'])
                    .videoCodec('libx264')
                    .output(outputPath)
                    .on('end', resolve)
                    .on('error', reject)
                    .run();
            });
            
            results.push({ videoUrl: `/videos/${outputName}`, originalImage: image.originalname });
            fs.unlinkSync(image.path);
        } catch(e) {
            results.push({ error: `Failed for ${image.originalname}` });
        }
    }
    
    res.json({ success: true, videos: results, total: results.length });
});

