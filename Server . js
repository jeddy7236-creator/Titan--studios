    try {
        await new Promise((resolve, reject) => {
            ffmpeg()
                .input(videoFile.path)
                .input(musicFile.path)
                .outputOptions(['-c:v copy', '-c:a aac', '-map 0:v:0', '-map 1:a:0', '-shortest'])
                .output(outputPath)
                .on('end', resolve)
                .on('error', reject)
                .run();
