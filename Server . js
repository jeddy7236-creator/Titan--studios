const express = require('express');
const cors = require('cors');
const bcrypt = require('bcryptjs');
const jwt = require('jsonwebtoken');
const multer = require('multer');
const fs = require('fs');
const path = require('path');
const { v4: uuidv4 } = require('uuid');
const sqlite3 = require('sqlite3').verbose();
const ffmpeg = require('fluent-ffmpeg');
const ffmpegPath = require('ffmpeg-static');

const app = express();
const PORT = process.env.PORT || 3000;

ffmpeg.setFfmpegPath(ffmpegPath);

app.use(cors());
app.use(express.json({ limit: '500mb' }));
app.use(express.urlencoded({ extended: true, limit: '500mb' }));
app.use(express.static('public'));
app.use('/uploads', express.static('uploads'));

const dirs = ['uploads', 'public', 'public/videos', 'public/audio', 'public/images'];
dirs.forEach(dir => { if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true }); });

const db = new sqlite3.Database('./titan.db');

db.serialize(() => {
    db.run(`CREATE TABLE IF NOT EXISTS users (
        id TEXT PRIMARY KEY, username TEXT UNIQUE, email TEXT UNIQUE, 
        password TEXT, created_at DATETIME DEFAULT CURRENT_TIMESTAMP
    )`);
    db.run(`CREATE TABLE IF NOT EXISTS videos (
        id TEXT PRIMARY KEY, user_id TEXT, title TEXT, url TEXT, 
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP
    )`);
    db.run(`CREATE TABLE IF NOT EXISTS scripts (
        id TEXT PRIMARY KEY, user_id TEXT, topic TEXT, content TEXT, 
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP
    )`);
});

const auth = (req, res, next) => {
    const token = req.headers.authorization?.split(' ')[1];
    if (!token) return res.status(401).json({ error: 'Unauthorized' });
    try {
        const decoded = jwt.verify(token, 'titan_super_secret_key');
        req.user = decoded;
        next();
    } catch(e) { res.status(401).json({ error: 'Invalid token' }); }
};

app.post('/api/auth/signup', async (req, res) => {
    const { username, email, password } = req.body;
    if (!username || !email || !password) return res.status(400).json({ error: 'All fields required' });
    try {
        const hashed = await bcrypt.hash(password, 10);
        const userId = uuidv4();
        db.run('INSERT INTO users (id, username, email, password) VALUES (?,?,?,?)',
            [userId, username, email, hashed], (err) => {
            if (err) return res.status(400).json({ error: 'User exists' });
            const token = jwt.sign({ id: userId, username }, 'titan_super_secret_key', { expiresIn: '365d' });
            res.json({ token, user: { id: userId, username, email } });
        });
    } catch(e) { res.status(500).json({ error: 'Server error' }); }
});

app.post('/api/auth/login', (req, res) => {
    const { email, password } = req.body;
    db.get('SELECT * FROM users WHERE email = ?', [email], async (err, user) => {
        if (err || !user) return res.status(401).json({ error: 'Invalid credentials' });
        const valid = await bcrypt.compare(password, user.password);
        if (!valid) return res.status(401).json({ error: 'Invalid credentials' });
        const token = jwt.sign({ id: user.id, username: user.username }, 'titan_super_secret_key', { expiresIn: '365d' });
        res.json({ token, user: { id: user.id, username: user.username, email: user.email } });
    });
});

const upload = multer({ dest: 'uploads/' });

app.post('/api/video/image-to-video', auth, upload.single('image'), async (req, res) => {
    const imageFile = req.file;
    const { duration, text } = req.body;
    if (!imageFile) return res.status(400).json({ error: 'Image required' });
    
    const outputName = `${uuidv4()}.mp4`;
    const outputPath = path.join(__dirname, 'public/videos', outputName);
    const durations = parseInt(duration) || 5;
    
    try {
        await new Promise((resolve, reject) => {
            let command = ffmpeg()
                .input(imageFile.path)
                .loop(durations)
                .inputOptions('-stream_loop -1')
                .outputOptions([`-t ${durations}`, '-vf scale=1080:1920:force_original_aspect_ratio=decrease,pad=1080:1920:(ow-iw)/2:(oh-ih)/2'])
                .videoCodec('libx264')
                .output(outputPath);
            
            if (text) {
                command = command.outputOptions([`-vf drawtext=text='${text.replace(/'/g, "\\'")}':fontcolor=white:fontsize=48:x=(w-text_w)/2:y=h-100`]);
            }
            command.on('end', resolve).on('error', reject).run();
        });
        
        fs.unlinkSync(imageFile.path);
        const videoId = uuidv4();
        db.run('INSERT INTO videos (id, user_id, title, url) VALUES (?,?,?,?)',
            [videoId, req.user.id, `Titan Video`, `/videos/${outputName}`]);
        
        res.json({ success: true, videoUrl: `/videos/${outputName}`, videoId });
    } catch(error) {
        res.status(500).json({ error: 'Failed to create video' });
    }
});

app.post('/api/video/slideshow', auth, upload.array('images', 50), async (req, res) => {
    const images = req.files;
    const { durationPerImage } = req.body;
    if (!images || images.length === 0) return res.status(400).json({ error: 'Images required' });
    
    const outputName = `${uuidv4()}.mp4`;
    const outputPath = path.join(__dirname, 'public/videos', outputName);
    const duration = parseInt(durationPerImage) || 3;
    
    try {
        await new Promise((resolve, reject) => {
            const command = ffmpeg();
            images.forEach(img => command.input(img.path));
            command.inputOptions([`-framerate 1/${duration}`])
                .outputOptions(['-vf scale=1080:1920:force_original_aspect_ratio=decrease,pad=1080:1920:(ow-iw)/2:(oh-ih)/2', '-c:v libx264'])
                .output(outputPath)
                .on('end', resolve)
                .on('error', reject)
                .run();
        });
        
        images.forEach(img => fs.unlinkSync(img.path));
        res.json({ success: true, videoUrl: `/videos/${outputName}` });
    } catch(error) {
        res.status(500).json({ error: 'Slideshow failed' });
    }
});

app.post('/api/video/merge', auth, upload.array('videos', 10), async (req, res) => {
    const videos = req.files;
    if (!videos || videos.length < 2) return res.status(400).json({ error: 'At least 2 videos required' });
    
    const outputName = `${uuidv4()}.mp4`;
    const outputPath = path.join(__dirname, 'public/videos', outputName);
    
    try {
        const concatFile = path.join(__dirname, 'uploads', `merge_${uuidv4()}.txt`);
        const concatContent = videos.map(v => `file '${path.resolve(v.path)}'`).join('\n');
        fs.writeFileSync(concatFile, concatContent);
        
        await new Promise((resolve, reject) => {
            ffmpeg()
                .input(concatFile)
                .inputOptions(['-f concat', '-safe 0'])
                .videoCodec('libx264')
                .audioCodec('aac')
                .output(outputPath)
                .on('end', resolve)
                .on('error', reject)
                .run();
        });
        
        videos.forEach(v => fs.unlinkSync(v.path));
        fs.unlinkSync(concatFile);
        res.json({ success: true, videoUrl: `/videos/${outputName}` });
    } catch(error) {
        res.status(500).json({ error: 'Merge failed' });
    }
});

app.post('/api/video/resize', auth, upload.single('video'), async (req, res) => {
    const videoFile = req.file;
    const { platform } = req.body;
    if (!videoFile) return res.status(400).json({ error: 'Video required' });
    
    let dimensions = '1080:1920';
    if (platform === 'youtube') dimensions = '1920:1080';
    if (platform === 'instagram') dimensions = '1080:1080';
    if (platform === 'facebook') dimensions = '1280:720';
    
    const outputName = `${uuidv4()}.mp4`;
    const outputPath = path.join(__dirname, 'public/videos', outputName);
    
    try {
        await new Promise((resolve, reject) => {
            ffmpeg(videoFile.path)
                .outputOptions([`-vf scale=${dimensions}:force_original_aspect_ratio=decrease,pad=${dimensions}:(ow-iw)/2:(oh-ih)/2`])
                .videoCodec('libx264')
                .audioCodec('aac')
                .output(outputPath)
                .on('end', resolve)
                .on('error', reject)
                .run();
        });
        
        fs.unlinkSync(videoFile.path);
        res.json({ success: true, videoUrl: `/videos/${outputName}` });
    } catch(error) {
        res.status(500).json({ error: 'Resize failed' });
    }
});

