// Image upload (image-to-video flow)
app.post('/api/video/image-to-video', auth, (req, res) => {
    imageUpload.single('image')(req, res, async err => {
        if (err) return fail(res, err.message);
        if (!req.file) return fail(res, 'Image file required');
        try {
            const videoId = uuidv4();
            const url     = `/uploads/images/${req.file.filename}`;
            const title   = sanitize(req.body.title) || req.file.originalname;

            await dbRun(
                `INSERT INTO videos (id, user_id, title, filename, url, mime_type, file_size)
                 VALUES (?,?,?,?,?,?,?)`,
                [videoId, req.user.id, title, req.file.filename, url, req.file.mimetype, req.file.size]
            );

            ok(res, { videoId, videoUrl: url, title, size: req.file.size });
        } catch (e) {
            fs.unlink(req.file.path, () => {});
            fail(res, 'Failed to save record', 500);
        }
    });
});

// Direct video upload with thumbnail + duration
app.post('/api/video/upload', auth, (req, res) => {
    videoUpload.single('video')(req, res, async err => {
        if (err) return fail(res, err.message);
        if (!req.file) return fail(res, 'Video file required');

        const videoId   = uuidv4();
        const filePath  = req.file.path;
        const url       = `/uploads/videos/${req.file.filename}`;
        const title     = sanitize(req.body.title) || req.file.originalname;
        const thumbName = `${videoId}.jpg`;

        try {
            const [duration, thumbnail] = await Promise.all([
                getMediaDuration(filePath),
                generateThumbnail(filePath, thumbName)
            ]);

            await dbRun(
                `INSERT INTO videos (id, user_id, title, filename, url, thumbnail, duration, mime_type, file_size)
                 VALUES (?,?,?,?,?,?,?,?,?)`,
                [videoId, req.user.id, title, req.file.filename, url,
                 thumbnail, duration, req.file.mimetype, req.file.size]
            );

            ok(res, { videoId, videoUrl: url, thumbnail, duration, title, size: req.file.size });
        } catch (e) {
            fs.unlink(filePath, () => {});
            fail(res, 'Failed to process video', 500);
        }
    });
});

// List videos (paginated)
app.get('/api/user/videos', auth, async (req, res) => {
    try {
        const page   = Math.max(1, parseInt(req.query.page)  || 1);
        const limit  = Math.min(50, parseInt(req.query.limit) || 20);
        const offset = (page - 1) * limit;

        const [videos, total] = await Promise.all([
            dbAll(`SELECT * FROM videos WHERE user_id=? ORDER BY created_at DESC LIMIT ? OFFSET ?`,
                  [req.user.id, limit, offset]),
            dbGet(`SELECT COUNT(*) AS c FROM videos WHERE user_id=?`, [req.user.id])
        ]);

        ok(res, { videos, total: total?.c || 0, page, limit,
                  pages: Math.ceil((total?.c || 0) / limit) });
    } catch (e) { fail(res, 'Failed to fetch videos', 500); }
});

// Get single video + increment views
app.get('/api/videos/:id', auth, async (req, res) => {
    try {
        const video = await dbGet('SELECT * FROM videos WHERE id=? AND user_id=?',
