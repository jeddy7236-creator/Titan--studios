// Get profile + stats
app.get('/api/user/profile', auth, async (req, res) => {
    try {
        const user = await dbGet(
            `SELECT id, username, email, display_name, avatar_url, bio, role, plan, created_at, last_login
             FROM users WHERE id=?`, [req.user.id]);
        if (!user) return fail(res, 'User not found', 404);

        const [vCount, sCount, aCount] = await Promise.all([
            dbGet('SELECT COUNT(*) AS c FROM videos  WHERE user_id=?', [req.user.id]),
            dbGet('SELECT COUNT(*) AS c FROM scripts WHERE user_id=?', [req.user.id]),
            dbGet('SELECT COUNT(*) AS c FROM audio   WHERE user_id=?', [req.user.id]),
        ]);

        ok(res, { user: { ...user, stats: {
            videos : vCount?.c || 0,
            scripts: sCount?.c || 0,
            audio  : aCount?.c || 0,
        }}});
    } catch (e) { fail(res, 'Failed to fetch profile', 500); }
});

// Update profile
app.patch('/api/user/profile', auth, async (req, res) => {
    try {
        const display = sanitize(req.body.display_name);
        const bio     = sanitize(req.body.bio).slice(0, 300);
        await dbRun(
            `UPDATE users SET display_name=?, bio=?, updated_at=CURRENT_TIMESTAMP WHERE id=?`,
            [display || null, bio || null, req.user.id]
        );
        ok(res, { message: 'Profile updated' });
    } catch (e) { fail(res, 'Failed to update profile', 500); }
});

// Change password
app.post('/api/user/change-password', auth, async (req, res) => {
    try {
        const { current_password, new_password } = req.body;
        if (!current_password || !new_password)
            return fail(res, 'Both passwords required');
        if (new_password.length < 8)
            return fail(res, 'New password must be at least 8 characters');

        const user  = await dbGet('SELECT password FROM users WHERE id=?', [req.user.id]);
        const valid = await bcrypt.compare(current_password, user.password);
        if (!valid) return fail(res, 'Current password is incorrect', 401);

        const hashed = await bcrypt.hash(new_password, 12);
        await dbRun('UPDATE users SET password=?, updated_at=CURRENT_TIMESTAMP WHERE id=?',
            [hashed, req.user.id]);
        ok(res, { message: 'Password changed successfully' });
    } catch (e) { fail(res, 'Failed to change password', 500); }
});

