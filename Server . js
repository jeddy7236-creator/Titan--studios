// ─── Database ─────────────────────────────────────────────────────────────────
const db = new sqlite3.Database('./titan.db', err => {
    if (err) { console.error('DB failed:', err.message); process.exit(1); }
    console.log('Database connected');
});

db.run('PRAGMA journal_mode = WAL');
db.run('PRAGMA foreign_keys = ON');

db.serialize(() => {
    // Users table
    db.run(`CREATE TABLE IF NOT EXISTS users (
        id           TEXT PRIMARY KEY,
        username     TEXT UNIQUE NOT NULL,
        email        TEXT UNIQUE NOT NULL,
        password     TEXT NOT NULL,
        display_name TEXT,
        avatar_url   TEXT,
        bio          TEXT,
        role         TEXT NOT NULL DEFAULT 'user',
        plan         TEXT NOT NULL DEFAULT 'free',
        is_active    INTEGER NOT NULL DEFAULT 1,
        created_at   DATETIME DEFAULT CURRENT_TIMESTAMP,
        updated_at   DATETIME DEFAULT CURRENT_TIMESTAMP,
        last_login   DATETIME
    )`);

    // Videos table
    db.run(`CREATE TABLE IF NOT EXISTS videos (
        id          TEXT PRIMARY KEY,
        user_id     TEXT NOT NULL,
        title       TEXT,
        description TEXT,
        filename    TEXT NOT NULL,
        url         TEXT NOT NULL,
        thumbnail   TEXT,
        duration    REAL,
        file_size   INTEGER,
        mime_type   TEXT,
        status      TEXT NOT NULL DEFAULT 'ready',
        views       INTEGER NOT NULL DEFAULT 0,
        created_at  DATETIME DEFAULT CURRENT_TIMESTAMP,
        FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
    )`);

    // Scripts table
    db.run(`CREATE TABLE IF NOT EXISTS scripts (
        id          TEXT PRIMARY KEY,
        user_id     TEXT NOT NULL,
        title       TEXT,
        topic       TEXT NOT NULL,
        platform    TEXT,
        tone        TEXT,
        content     TEXT NOT NULL,
        hooks       TEXT,
        word_count  INTEGER,
        is_favorite INTEGER NOT NULL DEFAULT 0,
        created_at  DATETIME DEFAULT CURRENT_TIMESTAMP,
        updated_at  DATETIME DEFAULT CURRENT_TIMESTAMP,
        FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
    )`);

    // Audio table
    db.run(`CREATE TABLE IF NOT EXISTS audio (
        id         TEXT PRIMARY KEY,
        user_id    TEXT NOT NULL,
        title      TEXT,
        filename   TEXT NOT NULL,
        url        TEXT NOT NULL,
        duration   REAL,
        file_size  INTEGER,
        mime_type  TEXT,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
    )`);

    // Performance indexes
    db.run(`CREATE INDEX IF NOT EXISTS idx_videos_user  ON videos(user_id)`);
    db.run(`CREATE INDEX IF NOT EXISTS idx_scripts_user ON scripts(user_id)`);
    db.run(`CREATE INDEX IF NOT EXISTS idx_audio_user   ON audio(user_id)`);
    db.run(`CREATE INDEX IF NOT EXISTS idx_users_email  ON users(email)`);
});

// ─── DB Promise Helpers ───────────────────────────────────────────────────────
const dbGet = (sql, p = []) => new Promise((res, rej) =>
    db.get(sql, p, (e, row) => e ? rej(e) : res(row)));

const dbRun = (sql, p = []) => new Promise((res, rej) =>
    db.run(sql, p, function(e) { e ? rej(e) : res({ id: this.lastID, changes: this.changes }); }));

const dbAll = (sql, p = []) => new Promise((res, rej) =>
    db.all(sql, p, (e, rows) => e ? rej(e) : res(rows)));

// ─── Response Helpers ─────────────────────────────────────────────────────────
const ok   = (res, data, status = 200) => res.status(status).json({ success: true,  ...data });
const fail = (res, msg,  status = 400) => res.status(status).json({ success: false, error: msg });

// ─── Utility Helpers ──────────────────────────────────────────────────────────
const sanitize     = s => String(s || '').trim().slice(0, 1000);
const validateEmail= e => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e);
const wordCount    = s => s.trim().split(/\s+/).length;
const jsonParse    = (s, fb = []) => { try { return JSON.parse(s); } catch { return fb; } };

// ─── Auth Middleware ──────────────────────────────────────────────────────────
const auth = (req, res, next) => {
    const header = req.headers.authorization || '';
    if (!header.startsWith('Bearer ')) return fail(res, 'Authorization header missing', 401);
    try {
        req.user = jwt.verify(header.slice(7), JWT_SECRET);
        next();
    } catch (e) {
        fail(res, e.name === 'TokenExpiredError' ? 'Token expired' : 'Invalid token', 401);
    }
};

const adminOnly = (req, res, next) =>
    req.user?.role === 'admin' ? next() : fail(res, 'Admin access required', 403);

// ─── Multer Storage Factory ───────────────────────────────────────────────────
const makeStorage = subfolder => multer.diskStorage({
    destination: (req, file, cb) => cb(null, `uploads/${subfolder}/`),
    filename:    (req, file, cb) => cb(null, `${uuidv4()}${path.extname(file.originalname).toLowerCase()}`)
});

const imageUpload = multer({
    storage: makeStorage('images'),
    limits:  { fileSize: 50 * 1024 * 1024 },
    fileFilter: (req, file, cb) => {
        ['image/jpeg','image/png','image/webp','image/gif'].includes(file.mimetype)
            ? cb(null, true)
            : cb(new Error('Only JPEG, PNG, WebP, GIF allowed'));
    }
});

const videoUpload = multer({
    storage: makeStorage('videos'),
    limits:  { fileSize: 500 * 1024 * 1024 },
    fileFilter: (req, file, cb) => {
        ['video/mp4','video/quicktime','video/x-msvideo','video/webm','video/mpeg'].includes(file.mimetype)
            ? cb(null, true)
            : cb(new Error('Only MP4, MOV, AVI, WebM, MPEG allowed'));
    }
});

const audioUpload = multer({
    storage: makeStorage('audio'),
    limits:  { fileSize: 100 * 1024 * 1024 },
    fileFilter: (req, file, cb) => {
        ['audio/mpeg','audio/wav','audio/ogg','audio/mp4','audio/aac'].includes(file.mimetype)
            ? cb(null, true)
            : cb(new Error('Only MP3, WAV, OGG, AAC allowed'));
    }
});

// ─── FFmpeg Helpers ───────────────────────────────────────────────────────────
const getMediaDuration = filePath => new Promise(res =>
    ffmpeg.ffprobe(filePath, (err, meta) =>
        res(err ? null : (meta?.format?.duration || null))));

const generateThumbnail = (videoPath, thumbName) => new Promise(res => {
    ffmpeg(videoPath)
        .screenshots({ timestamps: ['5%'], filename: thumbName, folder: 'uploads/thumbnails', size: '640x?' })
        .on('end',   () => res(`/uploads/thumbnails/${thumbName}`))
        .on('error', err => { console.warn('Thumbnail skipped:', err.message); res(null); });
});

