const express = require('express');
const cors = require('cors');
const bcrypt = require('bcryptjs');
const jwt = require('jsonwebtoken');
const multer = require('multer');
const fs = require('fs');
const path = require('path');
const { v4: uuidv4 } = require('uuid');
const sqlite3 = require('sqlite3').verbose();

let ffmpeg, ffmpegPath;
try {
    ffmpeg = require('fluent-ffmpeg');
    ffmpegPath = require('ffmpeg-static');
    if (ffmpegPath) ffmpeg.setFfmpegPath(ffmpegPath);
    console.log('FFmpeg loaded');
} catch(e) {
    console.log('FFmpeg not available');
}

const app = express();
const PORT = process.env.PORT || 3000;
const JWT_SECRET = process.env.JWT_SECRET || 'titan_secret_key';

app.use(cors());
app.use(express.json({ limit: '50mb' }));
app.use(express.urlencoded({ extended: true, limit: '50mb' }));
app.use(express.static('public'));

const dirs = ['public', 'public/uploads', 'public/videos', 'public/audio'];
dirs.forEach(dir => { if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true }); });

const db = new sqlite3.Database('./titan.db');

db.serialize(() => {
    db.run(`CREATE TABLE IF NOT EXISTS users (
        id TEXT PRIMARY KEY,
        username TEXT UNIQUE,
        email TEXT UNIQUE,
        password TEXT,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP
    )`);
    db.run(`CREATE TABLE IF NOT EXISTS videos (
        id TEXT PRIMARY KEY,
        user_id TEXT,
        url TEXT,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP
    )`);
    db.run(`CREATE TABLE IF NOT EXISTS scripts (
        id TEXT PRIMARY KEY,
        user_id TEXT,
        topic TEXT,
        content TEXT,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP
    )`);
});

const auth = (req, res, next) => {
    const token = req.headers.authorization?.split(' ')[1];
    if (!token) return res.status(401).json({ error: 'Unauthorized' });
    try {
        req.user = jwt.verify(token, JWT_SECRET);
        next();
    } catch(e) {
        res.status(401).json({ error: 'Invalid token' });
    }
};

app.post('/api/auth/signup', async (req, res) => {
    const { username, email, password } = req.body;
    if (!username || !email || !password) {
        return res.status(400).json({ error: 'All fields required' });
    }
    try {
        const hashed = await bcrypt.hash(password, 10);
        const userId = uuidv4();
        db.run('INSERT INTO users (id, username, email, password) VALUES (?,?,?,?)',
            [userId, username, email, hashed], (err) => {
            if (err) return res.status(400).json({ error: 'User exists' });
            const token = jwt.sign({ id: userId, username }, JWT_SECRET, { expiresIn: '30d' });
            res.json({ token, user: { id: userId, username, email } });
        });
    } catch(e) {
        res.status(500).json({ error: 'Server error' });
    }
});

app.post('/api/auth/login', (req, res) => {
    const { email, password } = req.body;
    db.get('SELECT * FROM users WHERE email = ?', [email], async (err, user) => {
        if (err || !user) return res.status(401).json({ error: 'Invalid credentials' });
        const valid = await bcrypt.compare(password, user.password);
        if (!valid) return res.status(401).json({ error: 'Invalid credentials' });
        const token = jwt.sign({ id: user.id, username: user.username }, JWT_SECRET, { expiresIn: '30d' });
        res.json({ token, user: { id: user.id, username: user.username, email: user.email } });
    });
});

app.get('/api/user/profile', auth, (req, res) => {
    db.get('SELECT id, username, email FROM users WHERE id = ?', [req.user.id], (err, user) => {
        res.json(user || {});
    });
});

const upload = multer({ dest: 'public/uploads/' });

app.post('/api/video/image-to-video', auth, upload.single('image'), (req, res) => {
    if (!req.file) return res.status(400).json({ error: 'Image required' });
    const videoUrl = `/uploads/${req.file.filename}`;
    const videoId = uuidv4();
    db.run('INSERT INTO videos (id, user_id, url) VALUES (?,?,?)', [videoId, req.user.id, videoUrl]);
    res.json({ success: true, videoUrl });
});

app.post('/api/ai/generate-script', auth, (req, res) => {
    const { topic, tone } = req.body;
    const script = `🔥 ${topic.toUpperCase()} 🔥\n\nHere's what works:\n1. Start today\n2. Stay consistent\n3. Never give up\n\nSave this video!\n\n#${topic.replace(/ /g, '')}`;
    const hooks = [`🎯 "${topic} hack"`, `🔥 "Get this right"`];
    const scriptId = uuidv4();
    db.run('INSERT INTO scripts (id, user_id, topic, content) VALUES (?,?,?,?)', [scriptId, req.user.id, topic, script]);
    res.json({ success: true, script, hooks });
});

app.get('/api/user/videos', auth, (req, res) => {
    db.all('SELECT * FROM videos WHERE user_id = ? ORDER BY created_at DESC', [req.user.id], (err, videos) => {
        res.json(videos || []);
    });
});

app.get('/api/user/scripts', auth, (req, res) => {
    db.all('SELECT * FROM scripts WHERE user_id = ? ORDER BY created_at DESC', [req.user.id], (err, scripts) => {
        res.json(scripts || []);
    });
});

app.get('/health', (req, res) => {
    res.json({ status: 'ok' });
});

app.listen(PORT, () => {
    console.log(`TITAN STUDIOS RUNNING on port ${PORT}`);
