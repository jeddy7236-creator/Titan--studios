    `⚡ "I wish someone told me this about ${topic} sooner"`,
    `🚨 "Do NOT try ${topic} until you watch this"`,
];

const CTAS = [
    '💾 Save this for when you need it most.',
    '👇 Drop your thoughts in the comments.',
    '🔁 Share with someone who needs to see this.',
    '➕ Follow for more content like this.',
    '🔔 Turn on notifications — more coming soon.',
];

// Generate script
app.post('/api/ai/generate-script', auth, async (req, res) => {
    try {
        const topic    = sanitize(req.body.topic);
        const platform = sanitize(req.body.platform) || 'tiktok';
        const tone     = sanitize(req.body.tone)     || 'motivation';
        const title    = sanitize(req.body.title)    || `${topic} — ${tone}`;

        if (!topic || topic.length < 2)
            return fail(res, 'Topic must be at least 2 characters');

        const generator = SCRIPT_TEMPLATES[tone] || SCRIPT_TEMPLATES.motivation;
        const script    = generator(topic);
        const hooks     = getHooks(topic);
        const cta       = CTAS[Math.floor(Math.random() * CTAS.length)];
        const wc        = wordCount(script);

        const scriptId = uuidv4();
        await dbRun(
            `INSERT INTO scripts (id, user_id, title, topic, platform, tone, content, hooks, word_count)
             VALUES (?,?,?,?,?,?,?,?,?)`,
            [scriptId, req.user.id, title, topic, platform, tone,
             script, JSON.stringify(hooks), wc]
        );

        ok(res, { scriptId, title, script, hooks, cta, word_count: wc, platform, tone });
    } catch (e) {
        console.error('Script error:', e);
        fail(res, 'Failed to generate script', 500);
    }
});

// List scripts (paginated + filter by tone)
app.get('/api/user/scripts', auth, async (req, res) => {
    try {
        const page   = Math.max(1, parseInt(req.query.page)  || 1);
        const limit  = Math.min(50, parseInt(req.query.limit) || 20);
        const tone   = sanitize(req.query.tone);
        const offset = (page - 1) * limit;

        const where  = tone ? 'AND tone=?' : '';
        const base   = [req.user.id, ...(tone ? [tone] : [])];

        const [scripts, total] = await Promise.all([
            dbAll(`SELECT * FROM scripts WHERE user_id=? ${where} ORDER BY created_at DESC LIMIT ? OFFSET ?`,
                  [...base, limit, offset]),
            dbGet(`SELECT COUNT(*) AS c FROM scripts WHERE user_id=? ${where}`, base)
        ]);

        const parsed = scripts.map(s => ({ ...s, hooks: jsonParse(s.hooks) }));
        ok(res, { scripts: parsed, total: total?.c || 0, page, limit });
    } catch (e) { fail(res, 'Failed to fetch scripts', 500); }
});

